# KBBot — Knowledge Base Bot (Nostr DM-based)
KBBOT_LLM_API_KEY=your_google_api_key_here
KBBOT_LLM_MODEL=gemini-3-flash-preview
# KBBOT_LLM_BASE_URL=            # Optional: custom LLM endpoint URL
# Should be unique name
KBBOT_NAMETAG=kbbot
KBBOT_NETWORK=testnet
# KBBOT_MAX_HISTORY_MESSAGES=20

# Viktor — DM-based research assistant
VIKTOR_LLM_API_KEY=your_llm_api_key_here
VIKTOR_LLM_MODEL=gpt-oss
VIKTOR_LLM_BASE_URL=https://api.openai.com/v1
# Should be unique name
VIKTOR_NAMETAG=viktor
VIKTOR_NETWORK=testnet

# SearXNG search endpoint (used by mcp-web; default points to internal Docker service)
SEARXNG_URL=http://searxng:8080
# SEARXNG_KEY=

# Unicity Oracle debug logging
# ORACLE_DEBUG=true
